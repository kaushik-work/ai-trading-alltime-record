# Claude API
ANTHROPIC_API_KEY=your_claude_api_key_here

# Zerodha Kite Connect — https://developers.kite.trade/
# 1. Create an app at developers.kite.trade to get API key + secret
# 2. Run `python scripts/get_token.py` each morning to generate the access token
ZERODHA_USER_ID=AB1234
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here
ZERODHA_ACCESS_TOKEN=             # generated daily — do not set manually

# Dashboard Auth (REQUIRED — change before deploying)
DASHBOARD_USER=your_username
DASHBOARD_PASS=your_strong_password_here
DASHBOARD_SECRET=your_random_jwt_secret_here   # generate: python -c "import secrets; print(secrets.token_hex(32))"

# Trading Mode
TRADING_MODE=paper                # "paper" = simulation | "live" = real money

# Risk Management
MAX_TRADE_AMOUNT=10000
MAX_DAILY_LOSS=5000
MAX_OPEN_POSITIONS=5
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0

# Telegram Notifications (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
