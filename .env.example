# Zerodha credentials (used by jugaad-trader — no paid API key needed)
ZERODHA_USER_ID=your_zerodha_user_id
ZERODHA_PASSWORD=your_zerodha_password
ZERODHA_TOTP_SECRET=your_totp_secret_key  # from Google Authenticator setup

# Zerodha Kite Connect (optional — for future upgrade)
# KITE_API_KEY=your_api_key_here
# KITE_API_SECRET=your_api_secret_here
# KITE_ACCESS_TOKEN=your_access_token_here

# Claude API
ANTHROPIC_API_KEY=your_claude_api_key_here

# Encryption passphrase (optional — if set, encrypts the local key with this password)
BOT_PASSPHRASE=

# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# Risk Management
MAX_TRADE_AMOUNT=10000
MAX_DAILY_LOSS=5000
MAX_OPEN_POSITIONS=5
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0

# Telegram Notifications (optional — leave blank to disable)
# How to get these:
#   1. Message @BotFather on Telegram → /newbot → copy the token
#   2. Message @userinfobot on Telegram → it shows your Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
