# Angel One SmartAPI — required for live market data and trading
ANGEL_API_KEY=          # from smartapi.angelbroking.com → My Profile → API
ANGEL_CLIENT_ID=        # your Angel One client ID (e.g. A123456)
ANGEL_PASSWORD=         # your MPIN (4-digit, not login password)
ANGEL_TOTP_TOKEN=       # base32 secret from TOTP setup (NOT the 6-digit code)
                        # Get it at: smartapi.angelbroking.com → Enable TOTP
                        # Save the SECRET STRING, not the QR image

# Angel One session tokens — set automatically at runtime, do NOT hardcode
# ANGEL_JWT_TOKEN=
# ANGEL_REFRESH_TOKEN=
# ANGEL_FEED_TOKEN=
# ANGEL_TOKEN_SET_AT=

# Anthropic (Claude AI — used for signal analysis)
ANTHROPIC_API_KEY=      # from console.anthropic.com

# Trading mode: "live" places real orders, "paper" simulates
TRADING_MODE=paper

# Database path (leave blank to use default db/trading.db)
# DB_PATH=

# Telegram alerts (optional — leave blank to disable)
# TELEGRAM_BOT_TOKEN=   # from @BotFather on Telegram
# TELEGRAM_CHAT_ID=     # your chat ID (send /start to @userinfobot)
