# ──────────────────────────────────────────────────────────────────────────────
# AI Trading All-Time Record — .env template
#
# Risk dials (LEVERAGE, capital %, kill switches) live in
# core/risk_management.py, NOT here. PR review, not silent edits.
# ──────────────────────────────────────────────────────────────────────────────

# === DELTA EXCHANGE INDIA (crypto live trading) ==============================
# Generate keys at delta.exchange → Profile → API Keys.
# REQUIRED scopes: Read + Trade.
# REQUIRED whitelist: your droplet's egress IP (curl ifconfig.me to find it).
DELTA_API_KEY=
DELTA_API_SECRET=
DELTA_BASE_URL=https://api.india.delta.exchange   # default, override only if needed

# Optional crypto runtime overrides (all have sensible code-side defaults):
# CRYPTO_TRADING_MODE=live                # or "paper" for simulation
# ENABLE_CRYPTO_RUNNER=1                  # set 0 to disable bot startup
# CRYPTO_TICK_SECONDS=2
# CRYPTO_LEVERAGE=3
# CRYPTO_BTC_CAPITAL_PCT=0.50
# CRYPTO_ETH_CAPITAL_PCT=0.50
# USD_INR_RATE=86                         # used for INR → USD pool conversion

# === MONGODB =================================================================
MONGODB_URL=
MONGODB_DB_NAME=

# === DASHBOARD AUTH ==========================================================
DASHBOARD_USER=
DASHBOARD_PASS=
DASHBOARD_SECRET=

# CORS origins for the frontend (comma-separated). Default already covers
# localhost + the production Vercel domain.
# DASHBOARD_ORIGINS=http://localhost:3000,https://ai-trading-alltime-record.vercel.app

# === NSE OPTION-CHAIN COLLECTORS (research data, no trading) =================
# Only needed if you run `docker compose --profile nse up -d` to start the
# NIFTY / BANKNIFTY / FINNIFTY / SENSEX 5-min OI snapshot collectors.
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=                          # 4-digit MPIN, not login password
ANGEL_TOTP_TOKEN=                        # base32 secret from TOTP setup
# Runtime tokens — Angel One refresh writes them back; don't hardcode:
# ANGEL_JWT_TOKEN=
# ANGEL_REFRESH_TOKEN=
# ANGEL_FEED_TOKEN=
# ANGEL_TOKEN_SET_AT=
